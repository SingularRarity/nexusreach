# NexusReach Environment Variables
# Copy this file to .env and fill in real values

# PostgreSQL
POSTGRES_USER=nexusreach
POSTGRES_PASSWORD=nexusreach_dev

# Database (used by backend)
DATABASE_URL=postgresql+asyncpg://nexusreach:nexusreach_dev@localhost:5432/nexusreach

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic Claude API (for AI match engine)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
