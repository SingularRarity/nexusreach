# ─────────────────────────────────────────────
# NexusReach — .gitignore
# Stack: Python/FastAPI + React/Vite + Docker
# ─────────────────────────────────────────────

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# Python 
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
/lib/
/lib64/
*.pyc
*.pyo
*.pyd
.Python

# Virtual Environments
.venv/
venv/
ENV/
env/
.env/

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc

# Mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff / Flake8
.ruff_cache/

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic
# Keep versions/ tracked, ignore local db state
backend/alembic/versions/__pycache__/

# Node / React / Vite 
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/
frontend/.vite/

# TypeScript
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# Vitest
frontend/coverage/

# Docker
# Keep docker-compose files tracked
# Ignore local override
docker-compose.override.yml

# IDEs & Editors
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
*.log.*

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing / E2E 
playwright-report/
test-results/
/e2e/screenshots/

# Misc
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/

# Local Docs
dev_docs/
